library(httr)
library(jsonlite)
readRenviron(".Renviron")
nycod_key <- Sys.getenv("NYCOD_KEY")
url <- "https://data.cityofnewyork.us/resource/erm2-nwe9.json"
where_clause <- "borough = 'MANHATTAN' AND (descriptor = 'Dog Waste' OR (descriptor = 'Animal Waste' AND additional_details = 'Dog'))"
out_dir <- "data/manhattan_dog_waste"
dir.create(out_dir, recursive = TRUE, showWarnings = FALSE)
page_size <- 50000
offset <- 0
page <- 0
repeat {
resp <- GET(
url,
query = list(
`$where`  = where_clause,
`$order`  = ":id",
`$limit`  = page_size,
`$offset` = offset
),
# add_headers(`X-App-Token` = "YOUR_APP_TOKEN"),
timeout(120)
)
stop_for_status(resp)
chunk <- fromJSON(content(resp, as = "text", encoding = "UTF-8"),
flatten = TRUE)
if (length(chunk) == 0 || (is.data.frame(chunk) && nrow(chunk) == 0)) break
# Coerce any list-columns to character so Arrow can write them cleanly
chunk[] <- lapply(chunk, function(col) if (is.list(col)) sapply(col, toString) else col)
fname <- file.path(out_dir, sprintf("part-%05d.parquet", page))
write_parquet(chunk, fname)
message(sprintf("wrote %s (%d rows)", fname, nrow(chunk)))
if (nrow(chunk) < page_size) break
offset <- offset + page_size
page   <- page + 1
}
